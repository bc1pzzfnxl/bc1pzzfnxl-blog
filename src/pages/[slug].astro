---
import MainLayout from "../layouts/MainLayout.astro";
import { Icon } from "astro-icon/components";

export const prerender = true;

export async function getStaticPaths() {
    const posts = import.meta.glob("../content/*.{md,mdx}", { eager: true });
    return Object.entries(posts).map(([path, post]) => {
        const slug = path.split("/").pop().replace(/\.(md|mdx)$/, "");
        return {
            params: { slug },
            props: { post },
        };
    });
}

const { post } = Astro.props;
const { Content, rawContent } = post;

// Extract title from filename
const slug = Astro.params.slug;
const title = decodeURIComponent(slug || "")
    .toLowerCase()
    .split("-")
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");

// Create a clean description from the first 160 characters of the content
const description = rawContent()
    .replace(/[#*`_\[\]]/g, '') // Remove basic markdown syntax
    .trim()
    .substring(0, 160) + "...";
---

<MainLayout title={title} description={description}>
    <article>
        <h1>{title}</h1>
        <Content components={{ Icon }} />
    </article>
    <a href="/" class="back-link">← Back</a>
</MainLayout>