---
import MainLayout from "../layouts/MainLayout.astro";
import { Icon } from "astro-icon/components";

export const prerender = true;

export async function getStaticPaths() {
    const posts = import.meta.glob("../content/*.{md,mdx}", { eager: true });
    return Object.entries(posts).map(([path, post]) => {
        const slug = path.split("/").pop().replace(/\.(md|mdx)$/, "");
        return {
            params: { slug },
            props: { post },
        };
    });
}

const { post } = Astro.props;
const { Content } = post;

// Extract title from filename (last part of path, without extension)
const slug = Astro.params.slug;
const title = decodeURIComponent(slug)
    .toLowerCase()
    .replace(/-/g, " ")
    .replace(/\b([a-zà-ÿ])/g, (l) => l.toUpperCase());
---

<MainLayout title={title}>
    <article>
        <h1>{title}</h1>
        <Content components={{ Icon }} />
    </article>
    <a href="/" class="back-link">← Back</a>
</MainLayout>