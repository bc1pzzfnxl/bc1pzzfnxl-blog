---
// src/layouts/MainLayout.astro
import { Icon } from "astro-icon/components";
const { title } = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{title}</title>
        <link id="favicon-link" rel="icon" type="image/svg+xml" href="/favicon-dark.svg" />
        <script is:inline>
            // This script is placed in the head to prevent FOUC (Flash of Unstyled Content)
            // It runs before the page is rendered to apply the correct theme.
            (function() {
                const theme = localStorage.getItem('theme');
                const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                const isDark = theme === 'dark' || (!theme && prefersDark);
                if (isDark) {
                    document.documentElement.classList.add('dark-mode');
                }
                
                // Update favicon based on theme
                window.addEventListener('DOMContentLoaded', () => {
                    const favicon = document.getElementById('favicon-link');
                    if (favicon) {
                        favicon.href = isDark ? '/favicon-light.svg' : '/favicon-dark.svg';
                    }
                });
            })();
        </script>
        <style is:global>
            @font-face {
                font-family: '0xProtoNerd';
                src: url('../assets/fonts/0xProto-Regular.woff2') format('woff2');
                font-weight: normal;
                font-style: normal;
                font-display: swap;
            }

            body {
                max-width: 680px;
                margin: 0 auto;
                padding: 40px 20px;
                font-family: '0xProtoNerd', -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica,
                    Arial, sans-serif;
                color: #111;
                line-height: 1.6;
                transition: background-color 0.3s ease, color 0.3s ease;
            }

            /* Minimalist Header */
            header {
                margin-bottom: 60px;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }
            .header-left {
                display: flex;
                align-items: center;
                gap: 12px;
            }
            .site-logo {
                width: 32px;
                height: 32px;
            }
            .bear-black { display: block; }
            .bear-white { display: none; }
            html.dark-mode .bear-black { display: none; }
            html.dark-mode .bear-white { display: block; }

            h1.site-title a {
                color: #111;
                text-decoration: none;
                font-size: 1.2rem;
                font-weight: 700;
                letter-spacing: -0.5px;
            }
            .theme-toggle-button {
                background: none;
                border: none;
                cursor: pointer;
                padding: 5px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
            }
            .theme-toggle-button .icon {
                width: 24px;
                height: 24px;
                color: #111;
            }

            /* Links and list */
            a {
                color: #111;
                text-decoration: underline;
                text-decoration-thickness: 1px;
                text-underline-offset: 3px;
            }
            a:hover {
                background-color: #000;
                color: #fff;
                text-decoration: none;
            }

            ul {
                list-style: none;
                padding: 0;
            }
            li {
                margin-bottom: 12px;
                display: flex;
                align-items: baseline;
            }

            /* Article Typography */
            article h1 {
                font-size: 1.8rem;
                margin-bottom: 0.5rem;
                letter-spacing: -1px;
            }
            article p {
                margin-bottom: 1.5rem;
            }
            article ul {
                list-style: disc;
                padding-left: 20px;
                margin-bottom: 1.5rem;
            }
            article li {
                display: list-item;
                margin-bottom: 0.5rem;
            }
            .back-link {
                display: inline-block;
                margin-top: 40px;
                font-size: 0.9rem;
                opacity: 0.6;
            }
            
            /* Dark Mode Styles */
            html.dark-mode body {
                background-color: #111; /* Black background */
                color: #eee; /* Off-white text (less harsh) */
            }
            html.dark-mode h1.site-title a,
            html.dark-mode a {
                color: #fff; /* White links */
            }
            html.dark-mode a:hover {
                color: #d946ef; /* Keep your accent color */
            }
            html.dark-mode .theme-toggle-button .icon {
                color: #fff;
            }
            .moon-icon { display: none; }
            .sun-icon { display: block; }
            html.dark-mode .moon-icon { display: block; }
            html.dark-mode .sun-icon { display: none; }
        </style>
    </head>
    <body>
        <header>
            <div class="header-left">
                <img src="/favicon-dark.svg" alt="Bear icon" class="site-logo bear-black" />
                <img src="/favicon-light.svg" alt="Bear icon" class="site-logo bear-white" />
                <div class="site-title"><a href="/">bc1pzzfnxl</a></div>
            </div>
            <button class="theme-toggle-button" id="theme-toggle">
                <Icon name="heroicons-solid:sun" class="sun-icon icon" />
                <Icon name="heroicons-solid:moon" class="moon-icon icon" />
            </button>
        </header>
        <main>
            <slot />
        </main>
        <script>
            const themeToggle = document.getElementById('theme-toggle');
            
            themeToggle.addEventListener('click', () => {
                const isDarkMode = document.documentElement.classList.toggle('dark-mode');
                localStorage.setItem('theme', isDarkMode ? 'dark' : 'light');
                
                // Update favicon when toggled
                const favicon = document.getElementById('favicon-link');
                if (favicon) {
                    favicon.href = isDarkMode ? '/favicon-light.svg' : '/favicon-dark.svg';
                }
            });
        </script>
    </body>
</html>